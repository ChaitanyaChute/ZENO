{
  "name": "@repo/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./generated/prisma": {
      "types": "./src/generated/prisma/index.d.ts",
      "default": "./src/generated/prisma/index.js"
    }
  },
  "scripts": {
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ./prisma/schema.prisma",
    "postinstall": "pnpm run db:generate"
  },
  "dependencies": {
    "@prisma/client": "6.2.1"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "dotenv": "^17.4.2",
    "prisma": "6.2.1",
    "typescript": "5.9.2"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": ""
}
